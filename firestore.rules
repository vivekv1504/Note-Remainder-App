rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Notes collection - users can only access their own notes
    match /notes/{noteId} {
      // Allow read if the note belongs to the user
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Allow create if user is authenticated and userId matches
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Allow update/delete if user owns the note
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Users collection - for storing user preferences (theme, notifications, selected ringtone, etc.)
    match /users/{userId} {
      // Allow read/write only to the user's own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Custom ringtones subcollection - users can manage their own ringtones
      match /customRingtones/{ringtoneId} {
        // Allow users to read their own custom ringtones
        allow read: if request.auth != null && request.auth.uid == userId;

        // Allow users to create custom ringtones (with required fields)
        allow create: if request.auth != null && request.auth.uid == userId &&
          request.resource.data.keys().hasAll(['label', 'path']) &&
          request.resource.data.label is string &&
          request.resource.data.label.size() > 0 &&
          request.resource.data.label.size() <= 100 &&
          request.resource.data.path is string &&
          request.resource.data.path.size() > 0;

        // Allow users to delete their own custom ringtones
        allow delete: if request.auth != null && request.auth.uid == userId;

        // Do not allow updates to maintain ringtone integrity
        allow update: if false;
      }
    }
  }
}
